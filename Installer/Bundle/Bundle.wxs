<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:bal="http://schemas.microsoft.com/wix/BalExtension">
  <Bundle Name="SCSC Setup"
          Version="$(var.ProductVersion)"
          Manufacturer="CTP Platanares"
          UpgradeCode="{DD8CEAC0-C891-420D-8D1B-DA4E89AE79F4}">
    <BootstrapperApplicationRef Id="WixStandardBootstrapperApplication.HyperlinkLicense">
      <bal:WixStandardBootstrapperApplication
        SuppressRepair="no"
        LicenseUrl="https://example.invalid/scsc/license"
        Theme="hyperlinkLicense" />
    </BootstrapperApplicationRef>

    <Chain>
      <ExePackage Id="NetFx461"
                  SourceFile="..\Redist\NDP461-KB3102436-x86-x64-AllOS-ENU.exe"
                  DetectCondition="NETFRAMEWORK45 &gt;= '#461308'"
                  InstallCommand="/passive /norestart"
                  RepairCommand="/repair /passive /norestart"
                  PerMachine="yes"
                  Vital="yes"
                  Compressed="no" />

      <ExePackage Id="CrystalRuntime"
                  SourceFile="..\Redist\CRRuntime_64bit_13_0_40.msi"
                  DetectCondition="CRYSTAL_RUNTIME_INSTALLED"
                  InstallCommand="/qn"
                  PerMachine="yes"
                  Vital="yes"
                  Compressed="no" />

      <MsiPackage Id="SCSCAppMsi"
                  SourceFile="$(var.MsiSource)"
                  DisplayInternalUI="no"
                  Visible="no"
                  Vital="yes" />

      <ExePackage Id="DeploymentSetup"
                  SourceFile="$(var.AppExePath)"
                  InstallCommand="/deployment-setup"
                  PerMachine="yes"
                  Vital="no"
                  Compressed="no" />
    </Chain>
  </Bundle>
</Wix>
